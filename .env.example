# Server
PORT=3001
NODE_ENV=development

# CORS (comma-separated; required for cookie auth in production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT (min 32 characters each)
JWT_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookies (optional)
# COOKIE_DOMAIN=.yourdomain.com

# Account lifecycle
ACCOUNT_DELETION_GRACE_DAYS=60

# Database (used by Prisma CLI and runtime)
POSTGRESQL_URL=postgresql://user:password@localhost:5432/nuts?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Resend Email & OTP
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=no-reply@yourdomain.com
OTP_TTL_MIN=10
OTP_LENGTH=6

# Sentry
SENTRY_DSN=https://your_sentry_dsn_here
